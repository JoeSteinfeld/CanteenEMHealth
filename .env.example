# Create a Samsara API token with at least:
#   Read Tags (Setup & Administration) — required; tag objects include `sensors` for this app
#   Read Readings (Closed Beta) — required for Get Readings Snapshot
#   Read Assets — only if the tag list falls back to loading tags from assets
#
# https://developers.samsara.com/docs/authentication

SAMSARA_API_TOKEN=

# US (default). For EU: https://api.eu.samsara.com   For CA: https://api.ca.samsara.com
# List tags and readings use host root by default, e.g. {SAMSARA_API_BASE}/tags, /readings/latest
# If your org only supports legacy paths, set: SAMSARA_PATH_STYLE=v1
# SAMSARA_API_BASE=https://api.samsara.com

# Get Readings Snapshot entity type (default: sensor, from List tags → sensors)
# SAMSARA_READINGS_ENTITY_TYPE=sensor

# Optional (default 3001)
# PORT=3001

# Persistent sensor notes (SQLite). Default: ./data/sensor-notes.sqlite under the process cwd.
# NOTES_DB_PATH=/var/lib/your-app/sensor-notes.sqlite
